{
  "name": "halo-mcp",
  "version": "1.0.0",
  "description": "MCP server for HaloPSA - provides Claude with first-class access to HaloPSA",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/index.js",
    "dev": "npx tsx src/index.ts",
    "dev:http": "MCP_TRANSPORT=http npx tsx src/index.ts"
  },
  "keywords": [
    "mcp",
    "halopsa",
    "halo",
    "psa"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.4.0",
    "express": "^5.2.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
